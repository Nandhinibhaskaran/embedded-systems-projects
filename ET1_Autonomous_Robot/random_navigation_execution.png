d\":false},\"2850107578\":{\"name\":\"2850107578\",\"rule_id\":\"7nxmtzMrThjQ6ucoe2XHVB:100.00:20-7nxmty7pqZalN4EsCV24Cz\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"ask_chatgpt_system_message\":\"The user is referring to an ad shown to them about: {LABEL}. Your response MUST BE ABOUT THE ADS shown, since the user explicitly asked about them. They are using the 'Ask ChatGPT' feature and you must reply to the user query using the information about the ads, which is:\\n{DATA}\\n\\nFor example: if the user asks 'Tell me more about these' (or other wordings), then your answer should be about details or further information on products, services, locations etc described in the ad and the links in the ad.\",\"android_display_zoom_scale_threshold\":1,\"onboarding\":{\"screen_personalization_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/personalization_en.png\",\"card_image_url\":\"https://cdn.openai.com/chatgpt/clients/onboarding/onboarding-example-1.png\",\"screen_privacy_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/secure.png\",\"screen_trust_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/trusted_en.png\",\"screen_transparency_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/controls_en.png\",\"impression_count\":5},\"android_large_font_scale_threshold\":1.5,\"late_ads_event_discard_timeout_seconds\":5,\"late_ads_event_discard_timeout_after_message_end_visibility_seconds\":3.5},\"is_device_based\":false,\"passed\":true},\"1249441125\":{\"name\":\"1249441125\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"1426425582\":{\"name\":\"1426425582\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"Live-only create\",\"is_experiment_active\":false,\"is_user_in_experiment\":false}