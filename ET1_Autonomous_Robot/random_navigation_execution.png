\",\"TT\",\"AG\",\"GD\",\"SR\",\"BB\",\"GY\",\"BN\",\"GT\",\"SO\",\"NE\",\"RS\",\"CV\",\"DK\",\"BJ\",\"CI\",\"BZ\",\"BA\",\"GQ\",\"GA\",\"DJ\",\"MR\",\"RE\",\"GP\",\"MQ\",\"GF\",\"IE\",\"DO\",\"PA\",\"TN\",\"YT\",\"XK\",\"GM\",\"MK\",\"CG\",\"NA\",\"HR\",\"UY\",\"GI\",\"CR\",\"LR\",\"MW\",\"AD\",\"SC\",\"LS\",\"AL\",\"BH\",\"LI\",\"SZ\",\"LU\",\"CD\",\"OM\",\"MV\",\"BW\",\"CY\",\"MC\",\"KW\",\"PY\",\"MT\",\"TZ\",\"RW\",\"QA\"],\"sms\":[\"US\",\"CA\",\"JP\",\"KR\",\"FR\",\"TW\",\"TH\",\"FK\",\"NU\",\"TL\",\"VU\",\"SM\"]},\"is_device_based\":false,\"passed\":false},\"4082596618\":{\"name\":\"4082596618\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"bio_trusted_access_link\":\"https://openai.com/form/trusted-access-for-biology-research/\",\"cyber_trusted_access_link\":\"https://openai.com/form/enterprise-trusted-access-for-cyber/\"},\"is_device_based\":false,\"passed\":false},\"2076138851\":{\"name\":\"2076138851\",\"rule_id\":\"3QigorHh71tggge0e0kFbD\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_concurrency\":20},\"is_device_based\":false,\"group_name\":\"20\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"2048788910\":{\"name\":\"2048788910\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"intervalMs\":200,\"enabled\":3},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_web_search\":false,\"user_prompt_key\":\"good_option\",\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\"},\"is_device_based\":false,\"passed\":false},\"3774971069\":{\"name\":\"3774971069\",\"rule_id\":\"3wuW1nDxShKMpRhW6RD9w6-3wuW1lYvpZBi6rK0vJHwd4\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"tooltip\":\"Only includes tokens tracked after token-based pricing was enabled\"},\"is_device_based\":false,\"passed\":false}},\"layer_configs\":{\"1200251816\":{\"name\":\"1200251816\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"enable-join-workspaces-banner\":false},\"id_type\":\"userID\",\"is_device_based\":false,\"explicit_parameters\":[],\"undelegated_secondary_exposures\":[]},\"1671916711\":{\"name\":\"1671916711\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"enabled_see_if_you_qualify_variant\":false},\"id_type\":\"userID\",\"is_device_based\":false,\"explicit_parameters\":[],\"undelegated_secondary_exposures\":[]},\"1019211