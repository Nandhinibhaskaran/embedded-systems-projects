":false,\"group_name\":\"10k Threshold\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"783652697\":{\"name\":\"783652697\",\"rule_id\":\"3Fk7LTbG3NkesGBOqbIJwe:100.00:4-3Fk7LRwDBvaK9h3SP3N6dc\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"chatgpt.go\":{\"usd-bn\":600,\"usd-yt\":800,\"kzt\":339000,\"ils\":2500,\"sek\":8500,\"gbp\":700,\"usd-mv\":600,\"usd-re\":800,\"dkk\":6400,\"krw\":1300000,\"twd\":27000,\"nzd\":1400,\"eur-es\":800,\"aed\":3000,\"sgd\":1100,\"jpy\":140000,\"nok\":9900,\"myr\":2400,\"usd-mu\":600,\"usd-sc\":800,\"czk\":20000}},\"is_device_based\":true,\"passed\":true},\"1521940286\":{\"name\":\"1521940286\",\"rule_id\":\"2dprGiDHsVr2AQRVuaPGLU\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"group_name\":\"Control\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"3528236309\":{\"name\":\"3528236309\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"show_project_overview_chart\":true,\"show_impact_tab\":true,\"temp-sidebar-chat\":true,\"custom-time-range-selector\":true,\"show_benchmark_tab\":true,\"show_group_filter\":true,\"show_benchmark\":true,\"show_project_tab\":true,\"show_ui_polish\":true,\"can_see_analytics_viewer_role\":true,\"show_connector_project_cols\":true,\"show_classification_tab\":true,\"show_conversation_topic\":true,\"show_weekly_active_users_chart\":true,\"show_connector_overview_chart\":true,\"show_ai_champions_button\":true},\"is_device_based\":false,\"passed\":false},\"3608673692\":{\"name\":\"3608673692\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"sse_initial_open_timeout_ms\":0,\"sse_first_response_warning_ms\":120000,\"sse_between_bytes_timeout_ms\":60000},\"is_device_based\":false,\"passed\":false},\"1299917208\":{\"name\":\"1299917208\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"handoff_link_strategy\":\"legacy_root\"},\"is_device_based\":true,\"passed\":false},\"3747383021\":{\"name\":\"3747383021\",\"rule_id\":\"5jGtlP98oKdB7tDQLSZvur:100.00:1\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"google_calendar\":true,\"linear\":false,\"canva\":false,\"mcp\":false,\"box\":false,\"github\":true,\"google_drive\":true,\"notion\":false,\"gmail\":true,\"sharepoint\":false,\"outlook_email\":false,\"outlook_calendar\":false,\"dropbox\":false,\"teams\":false,\"hubspot\":false},\"is_device_based\":true,\"passed\":true},\"2426548489\":{\"name\":\"2426548489\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"673335100\",\"gateValue\":\"true\",\"ruleID\":\"2SST7QaGk0pDlX3sFKvDwO:100.00:11\"},{\"gate\":\"1033995237\",\"gateValue\":\"true\",\"ruleID\":\"FaUk24I1k6FuRoAiJIlvI\"},{\"gate\":\"1079440639\",\"gateValue\":\"false\",\"ruleID\":\"6gUxO6GUFWV1IvwiiDDgyY\"}],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"4005134340\":{\"name\":\"4005134340\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"1007700932\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"574611634\":{\"name\":\"574611634\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"connector_link_policies\":{\"connector_2128aebfecb84f64a069897515042a44\":{\"link_created_at_min\":\"2026-03-03T22:00:00Z\"}}},\"is_device_based\":false,\"passed\":false},\"2542357090\":{\"name\":\"2542357090\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"default_bootstrap_model_id\":\"gpt-5-5-instant\",\"campaigns\":{\"reaction_sticker_pack\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, friends, messaging habits, or creative preferences.\\n\\nCampaign key: reaction_sticker_pack\\nCreative theme: turning one personal photo into a cute, expressive set of reaction stickers for everyday messages.\\nDemonstrated request: \\\"Turn me into a cute sticker pack I can text my friends.\\\"\\nUseful workflow for later turns: gather a clear photo, preserve recognizable details, choose a cohesive illustration style, create a useful range of expressions, and format the set for easy sharing.\\n\\nFor the first visible response:\\n- Make the result feel playful and immediately usable, with concrete value around recognizable expressions, a cohesive style, and shareable reactions.\\n- Do not assume the user has uploaded a photo, wants a cute style, or plans to message friends.\\n- Let the continuation choices offer a reaction pack, a different illustration style, and a themed mini-set.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\"},\"personal_color_analysis\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign presented in Hindi. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, skin tone, gender, photos, location, language preference, or beauty preferences.\\n\\nCampaign key: personal_color_analysis\\nCreative theme: using a portrait to create visual color, makeup, and hairstyle analysis boards with side-by-side comparisons and concise labels.\\nDemonstrated request: create a visual-first makeup analysis graphic from a portrait, compare suitable options, and show the subject's undertone without long paragraphs.\\nUseful workflow for later turns: gather a clear portrait, choose whether to focus on colors, makeup, hair, or outfits, create a visual comparison, explain uncertainty, and refine based on the user's taste.\\n\\nFor the first visible response:\\n- Make visual style exploration feel accessible and confidence-building, with concrete value around color palettes, side-by-side comparisons, and personalized mockups.\\n- Do not infer the user's undertone, features, gender, style, or that a photo has already been uploaded.\\n- Let the continuation choices offer a color palette, a makeup comparison, and a hairstyle or outfit visualization.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\"},\"photo_cartoon\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Spanish. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, location, language preference, or creative style.\\n\\nCampaign key: photo_cartoon\\nCreative theme: transforming favorite personal photos into illustrated, cartoon, or anime-style images.\\nDemonstrated request: \\\"Si subo algunas de mis fotos favoritas, ¿puedes convertirlas en imágenes tipo caricatura?\\\"\\nUseful workflow for later turns: gather one or more photos, preserve recognizable identity and important details, choose an illustration direction, then generate and refine a polished transformation.\\n\\nFor the first visible response:\\n- Make the transformation feel personal and fun, with concrete value around choosing a style, preserving recognizable details, and creating a shareable result.\\n- Do not assume the user has uploaded photos, wants anime specifically, or resembles the featured subject.\\n- Let the continuation choices offer a cartoon portrait, a different illustration style, and a shareable visual format.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\"},\"interview_practice\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Japanese. Treat this as a soft signal of possible interest, never as a fact about the user's identity, employment, experience, industry, or interview plans.\\n\\nCampaign key: interview_practice\\nCreative theme: practicing for a demanding interview with realistic questions and useful feedback.\\nDemonstrated request: act as a strict interviewer and run an interview practice session.\\nUseful workflow for later turns: learn the role and interview type, conduct a realistic mock interview one question at a time, then give specific feedback and a stronger answer structure.\\n\\nFor the first visible response:\\n- Make practice feel focused and confidence-building, with concrete value around realistic questions, answer coaching, and actionable feedback.\\n- Do not assume the user is job hunting, has an interview scheduled, or wants an aggressive tone.\\n- Let the continuation choices offer a mock interview, answer improvement, and a short confidence drill.\\n- If the user changes topics later, help normally.\",\"enabled\":true},\"outfit_transfer\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, body, gender, appearance, wardrobe, shopping plans, event, location, budget, or preferences.\\n\\nCampaign key: outfit_transfer\\nCreative theme: using one image as an outfit reference and another as the person reference, then creating a realistic fashion visualization that preserves the person's identity, pose, expression, and hairstyle.\\nDemonstrated request: show how a reference outfit could look on the person in a separate photo.\\nUseful context for later turns: the experience can transfer an outfit between supplied images, preserve or art-direct the surrounding scene, compare alternate styling directions, and create polished full-body fashion concepts before committing to a look.\\n\\nFor the first visible response:\\n- Make visualization feel confiden